      "activity_logs": {
        "file": "activity_logs_tools.py",
        "doc_source": "",
        "register_fn": "register_activity_logs_tools",
        "tools": {
          "fetch_activity_logs_from_board": {
            "endpoint": "SDK monday_sdk.activity_logs.fetch_activity_logs_from_board",
            "description": "Fetch a page of activity logs.",
            "tier": "GET",
            "params": [
              {
                "name": "board_ids",
                "type": "int",
                "required": true,
                "description": "Board Id"
              },
              {
                "name": "page",
                "type": "int",
                "required": true,
                "description": "Page number to get, starting at 1."
              },
              {
                "name": "limit",
                "type": "int",
                "required": true,
                "description": "Number of items to get, the default is 25."
              },
              {
                "name": "from_date",
                "type": "str",
                "required": true,
                "description": "datetime in the format YYYY-MM-DDTHH:MM:SSZ"
              },
              {
                "name": "to_date",
                "type": "str",
                "required": true,
                "description": "datetime in the format YYYY-MM-DDTHH:MM:SSZ"
              }
            ],
            "response_fields": [
              {
                "name": "id",
                "type": "str"
              },
              {
                "name": "account_id",
                "type": "str"
              },
              {
                "name": "created_at",
                "type": "str"
              },
              {
                "name": "data",
                "type": "str"
              },
              {
                "name": "entity",
                "type": "str"
              },
              {
                "name": "event",
                "type": "str"
              },
              {
                "name": "user_id",
                "type": "str"
              }
            ],
            "schema": {
              "data": "ActivityLogListData",
              "result": "ActivityLogListResult"
            }
          },
          "fetch_all_activity_logs_from_board": {
            "endpoint": "SDK monday_sdk.activity_logs.fetch_all_activity_logs_from_board",
            "description": "Fetch all activity logs with automatic pagination and optional event filtering.",
            "tier": "GET",
            "params": [
              {
                "name": "board_ids",
                "type": "int",
                "required": true,
                "description": "Board Id"
              },
              {
                "name": "from_date",
                "type": "str",
                "required": true,
                "description": "datetime in the format YYYY-MM-DDTHH:MM:SSZ"
              },
              {
                "name": "to_date",
                "type": "str",
                "required": true,
                "description": "datetime in the format YYYY-MM-DDTHH:MM:SSZ"
              },
              {
                "name": "limit",
                "type": "int",
                "required": true,
                "description": "Number of items to get, the default is 25."
              },
              {
                "name": "events_filter",
                "type": "list[str]",
                "required": true,
                "description": "Filter activity logs by specific event types"
              }
            ],
            "response_fields": [
              {
                "name": "id",
                "type": "str"
              },
              {
                "name": "account_id",
                "type": "str"
              },
              {
                "name": "created_at",
                "type": "str"
              },
              {
                "name": "data",
                "type": "str"
              },
              {
                "name": "entity",
                "type": "str"
              },
              {
                "name": "event",
                "type": "str"
              },
              {
                "name": "user_id",
                "type": "str"
              }
            ],
            "schema": {
              "data": "ActivityLogListData",
              "result": "ActivityLogListResult"
            }
          }
        }
      },
